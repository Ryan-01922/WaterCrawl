# WaterCrawl API 配置
WATERCRAWL_BASE_URL=http://10.60.151.130:7109/api/v1/core
WATERCRAWL_API_KEY=你的WaterCrawl_API_Key

# GPUStack / Qwen3-32B 大模型配置
GPUSTACK_API_BASE=https://gpustack.stock.hnchasing.com/v1
GPUSTACK_API_KEY=你的GPUStack_API_Key
GPUSTACK_MODEL=qwen3-32b

# Redis 配置（连接服务器宿主机 Redis）
REDIS_HOST=host.docker.internal
REDIS_PORT=16379
REDIS_DB=0
REDIS_PASSWORD=mypassword123
# 也可直接用 REDIS_URL 覆盖以上配置：
# REDIS_URL=redis://:mypassword123@host.docker.internal:16379/0
